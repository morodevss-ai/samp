<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tablist_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/tablist_dim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#55FFFFFF" />

    <LinearLayout
        android:id="@+id/tablist_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#B3FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tablist_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Players"
                android:textColor="#1A1A1A"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/tablist_close"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="Close"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#1A1A1A" />
        </LinearLayout>

        <EditText
            android:id="@+id/tablist_search"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="10dp"
            android:background="#80FFFFFF"
            android:hint="Search player..."
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:textColor="#1A1A1A"
            android:textColorHint="#7A7A7A" />

        <LinearLayout
            android:id="@+id/tablist_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.15"
                android:text="ID"
                android:textColor="#4A4A4A"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.55"
                android:text="Name"
                android:textColor="#4A4A4A"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.15"
                android:gravity="end"
                android:text="Score"
                android:textColor="#4A4A4A"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.15"
                android:gravity="end"
                android:text="Ping"
                android:textColor="#4A4A4A"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="#33000000" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tablist_recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:overScrollMode="never" />

    </LinearLayout>

</FrameLayout>
