<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_modern"
    android:keepScreenOn="true">

    <!-- 🔴 Background Circles -->
    <ImageView
        android:id="@+id/bgTopRight"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:alpha="0.25"
        android:src="@drawable/bg_circle_red"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationX="20dp"
        android:translationY="-20dp" />

    <ImageView
        android:id="@+id/bgTopLeft"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:alpha="0.25"
        android:src="@drawable/bg_circle_red"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:translationX="-20dp"
        android:translationY="-20dp" />

    <!-- 🔹 Header (Logo + App Name) -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginEnd="10dp"
            android:src="@drawable/ic_app_logo"
            android:elevation="6dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kurdish"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RolePlay"
                android:textColor="@color/primary_red"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- 🔸 Bottom Info -->
    <LinearLayout
        android:id="@+id/bottomInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/placeholderSpace">

        <!-- 🌐 Social Icons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/discordBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/social_icon_bg"
                android:padding="5dp"
                android:src="@drawable/discord_logo" />

            <ImageView
                android:id="@+id/webBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/social_icon_bg"
                android:padding="5dp"
                android:src="@drawable/internet" />

            <ImageView
                android:id="@+id/youtubeBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/social_icon_bg"
                android:padding="5dp"
                android:src="@drawable/youtube_logo" />
        </LinearLayout>

        <!-- 🧾 Version Info -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/version_bg"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0.0"
                android:textColor="#80FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp" />

            <View
                android:layout_width="2dp"
                android:layout_height="16dp"
                android:layout_marginHorizontal="4dp"
                android:background="#40FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kurdish RolePlay"
                android:textColor="#80FFFFFF"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- ▶️ Play Button -->
        <FrameLayout
            android:id="@+id/btnPlay"
            android:layout_width="100dp"
            android:layout_height="40dp"
            android:background="@drawable/btn_play_modern"
            android:clickable="true"
            android:focusable="true"
            android:elevation="10dp"
            android:layout_gravity="center_horizontal">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play_arrow" />

        </FrameLayout>
    </LinearLayout>

    <!-- ⚫ Placeholder Space for Bottom Buttons -->
    <View
        android:id="@+id/placeholderSpace"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@android:color/transparent" />

</androidx.constraintlayout.widget.ConstraintLayout>
