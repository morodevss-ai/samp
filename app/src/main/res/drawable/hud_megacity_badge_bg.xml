<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:angle="25"
                android:startColor="#D0111A2A"
                android:centerColor="#C91A3048"
                android:endColor="#D00B1019" />
            <stroke
                android:width="1dp"
                android:color="#7EDCF6FF" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="20dp">
        <shape android:shape="rectangle">
            <corners android:radius="15dp" />
            <gradient
                android:angle="270"
                android:startColor="#52FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <item
        android:left="0dp"
        android:top="20dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:angle="90"
                android:startColor="#0076E8FF"
                android:endColor="#2B76E8FF" />
        </shape>
    </item>
</layer-list>
