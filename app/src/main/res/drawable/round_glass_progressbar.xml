<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- بکگراند Progress Bar (شیشه‌ای) --><item android:id="@android:id/background">
    <shape android:shape="rectangle">
        <corners android:radius="12dp"/>
        <solid android:color="#40FFFFFF"/> <!-- رنگ سفید با 25% شفافیت --></shape>
</item>

    <!-- پیشرفت Progress Bar (آبی) --><item android:id="@android:id/progress">
    <clip>
        <shape android:shape="rectangle">
            <corners android:radius="12dp"/>
            <solid android:color="#FF2196F3"/> <!-- رنگ آبی پررنگ --></shape>
    </clip>
</item>
</layer-list>
