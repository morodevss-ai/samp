<?xml version="1.0" encoding="utf-8"?>
<!-- Glass background for the bottom bar -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Semi-transparent color - this is the glass effect -->
    <solid android:color="#90333333" /> <!-- Semi-transparent gray -->

    <!-- Round the corners -->
    <corners android:radius="30dp" />

    <!-- A thin stroke for aesthetics -->
    <stroke
        android:width="1dp"
        android:color="#B0FFFFFF" />
</shape>

